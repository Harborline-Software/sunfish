    "tauri:build": "tauri build",
    "smoke": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/run-smoke.ps1",
    "smoke:nobuild": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/run-smoke.ps1 -SkipBuild",
    "smoke:test": "playwright test --config=smoke/playwright.config.ts"
  },
  "dependencies": {
