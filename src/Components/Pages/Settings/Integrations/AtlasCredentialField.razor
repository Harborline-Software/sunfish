@using Sunfish.UICore.Wayfinder.Integrations
@using System.Text
@using System.Text.Json.Nodes

@{
    var inputId = $"atlas-cred-{_instanceId}";
    var descId = Field.HelpText is { Length: > 0 } ? $"atlas-cred-desc-{_instanceId}" : null;
    var toggleId = $"atlas-cred-toggle-{_instanceId}";
    var isSecret = Field.Kind == CredentialFieldKind.Secret;
    var isUrl = Field.Kind == CredentialFieldKind.Url;
    var isReadOnly = Field.Kind == CredentialFieldKind.ReadOnlyOutput;
    var autocomplete = GetAutocomplete(Field.AutocompleteHint);
    var inputType = isSecret && !_showSecret ? "password" : isUrl ? "url" : "text";
}

<div class="atlas-cred-field">
    <label for="@inputId" class="atlas-cred-label">
        @Field.DisplayLabel
        @if (Field.IsRequired)
        {
            <span class="atlas-required-marker" aria-hidden="true"> *</span>
            <span class="sf-visually-hidden">(required)</span>
        }
    </label>

    @if (descId is not null)
    {
        <p id="@descId" class="atlas-cred-help">@Field.HelpText</p>
    }

    @if (isReadOnly)
    {
        @* ReadOnlyOutput: non-editable value display *@
        <output id="@inputId"
                class="atlas-cred-readonly"
                aria-describedby="@descId">@_value</output>
    }
    else
    {
        <div class="atlas-cred-input-row">
            @if (isSecret && HasExistingValue && !_touched)
            {
                @* SC 3.3.7: existing sensitive credential — "leave unchanged" placeholder.
                   Does NOT pre-populate with stored credential bytes. User must type to change. *@
                <input id="@inputId"
                       type="password"
                       class="atlas-cred-input atlas-cred-input--unchanged"
                       placeholder="••••••••"
                       autocomplete="@autocomplete"
                       aria-describedby="@descId"
                       aria-label="@($"{Field.DisplayLabel} — currently set. Type to replace, or leave blank to keep.")"
                       @oninput="HandleInput"
                       @onfocus="HandleExistingFocus" />
            }
            else
            {
                <input id="@inputId"
                       type="@inputType"
                       class="atlas-cred-input"
                       value="@_value"
                       placeholder="@Field.Placeholder"
                       autocomplete="@autocomplete"
                       aria-describedby="@descId"
                       required="@Field.IsRequired"
                       @oninput="HandleInput" />
            }

            @if (isSecret)
            {
                @* SC 4.1.2: show/hide toggle with aria-pressed + aria-controls *@
                <button type="button"
                        id="@toggleId"
                        class="atlas-cred-toggle"
                        aria-pressed="@(_showSecret ? "true" : "false")"
                        aria-controls="@inputId"
                        aria-label="@(_showSecret ? $"Hide {Field.DisplayLabel}" : $"Show {Field.DisplayLabel}")"
                        @onclick="ToggleSecret">
                    @(_showSecret ? "Hide" : "Show")
                </button>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public CredentialFieldSpec Field { get; set; } = default!;

    /// <summary>True when the provider already has a stored value for this credential key.</summary>
    [Parameter] public bool HasExistingValue { get; set; }

    /// <summary>Fired when the user changes a Secret field value.</summary>
    [Parameter] public EventCallback<(string Key, ReadOnlyMemory<byte> Bytes)> OnSensitiveChanged { get; set; }

    /// <summary>Fired when the user changes a non-Secret field value.</summary>
    [Parameter] public EventCallback<(string Key, JsonNode Value)> OnNonSensitiveChanged { get; set; }

    private readonly string _instanceId = Guid.NewGuid().ToString("N")[..8];
    private bool _showSecret;
    private bool _touched;
    private string _value = string.Empty;

    private static string GetAutocomplete(CredentialAutocompleteHint hint) => hint switch
    {
        CredentialAutocompleteHint.CurrentPassword => "current-password",
        CredentialAutocompleteHint.NewPassword => "new-password",
        CredentialAutocompleteHint.OneTimeCode => "one-time-code",
        CredentialAutocompleteHint.Username => "username",
        CredentialAutocompleteHint.Email => "email",
        CredentialAutocompleteHint.Url => "url",
        _ => "off",
    };

    private void HandleExistingFocus()
    {
        // First focus on an existing-value Secret field transitions to edit mode;
        // user must type to issue a new credential — the stored value is never surfaced.
        _touched = true;
        _value = string.Empty;
    }

    private async Task HandleInput(ChangeEventArgs e)
    {
        _touched = true;
        _value = e.Value?.ToString() ?? string.Empty;

        if (Field.Kind == CredentialFieldKind.Secret)
        {
            var bytes = Encoding.UTF8.GetBytes(_value).AsMemory();
            await OnSensitiveChanged.InvokeAsync((Field.Key, bytes));
        }
        else
        {
            JsonNode node = JsonValue.Create(_value)!;
            await OnNonSensitiveChanged.InvokeAsync((Field.Key, node));
        }
    }

    private void ToggleSecret()
    {
        _showSecret = !_showSecret;
        // Revealing a secret field in existing-value mode starts edit mode.
        if (!_touched && HasExistingValue && Field.Kind == CredentialFieldKind.Secret)
            _touched = true;
    }
}

<style>
    .atlas-cred-field { display: flex; flex-direction: column; gap: 0.25rem; margin-bottom: 0.875rem; }
    .atlas-cred-label { font-size: 0.875rem; font-weight: 600; color: #111; }
    .atlas-required-marker { color: #dc2626; }
    .atlas-cred-help { font-size: 0.8125rem; color: #666; margin: 0 0 0.25rem; line-height: 1.45; }
    .atlas-cred-input-row { display: flex; gap: 0.375rem; align-items: center; }
    .atlas-cred-input { flex: 1; padding: 0.5rem 0.625rem; border: 1px solid #d1d5db; border-radius: 5px; font-size: 0.875rem; font-family: inherit; }
    .atlas-cred-input:focus { outline: 2px solid #2563eb; outline-offset: 1px; border-color: #2563eb; }
    .atlas-cred-input--unchanged { color: #9ca3af; font-style: italic; }
    .atlas-cred-toggle { padding: 0.5rem 0.75rem; border: 1px solid #d1d5db; border-radius: 5px; background: #f9fafb; font-size: 0.8125rem; cursor: pointer; white-space: nowrap; }
    .atlas-cred-toggle:focus { outline: 2px solid #2563eb; outline-offset: 1px; }
    .atlas-cred-readonly { display: block; padding: 0.5rem 0.625rem; background: #f3f4f6; border: 1px solid #e5e7eb; border-radius: 5px; font-size: 0.875rem; font-family: monospace; word-break: break-all; }
    .sf-visually-hidden { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }
</style>
