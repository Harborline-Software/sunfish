@page "/cockpit/work-orders"
@layout CockpitLayout
@using Sunfish.Anchor.Services
@using Sunfish.Blocks.Maintenance.Models
@using Sunfish.Blocks.Maintenance.Services
@inject IMaintenanceService Maintenance
@inject AnchorSessionService Session
@inject NavigationManager Nav

<PageTitle>Work Orders · Cockpit</PageTitle>

@* W#29 Phase 3 — work-orders list. Per XO ruling: no property filter
   (WorkOrder has no PropertyId; W#62.1 will add it). Status + vendor
   filters map to ListWorkOrdersQuery; date-range filter applies
   client-side. *@

<header class="cockpit-wo-header">
    <div>
        <h1>Work Orders</h1>
        <p class="cockpit-wo-meta">@_workOrders.Count @(_workOrders.Count == 1 ? "work order" : "work orders")</p>
    </div>
    <div class="cockpit-wo-filters">
        <label for="wo-status">Status</label>
        <select id="wo-status" @bind="_statusFilter" @bind:after="LoadAsync">
            <option value="">All</option>
            @foreach (var status in Enum.GetValues<WorkOrderStatus>())
            {
                <option value="@status">@status</option>
            }
        </select>
    </div>
</header>

@if (_loadError is not null)
{
    <div class="cockpit-wo-error">
        <strong>Failed to load work orders.</strong>
        <p>@_loadError</p>
    </div>
}
else if (_workOrders.Count == 0)
{
    <p class="cockpit-wo-empty">No work orders match this filter.</p>
}
else
{
    <table class="cockpit-wo-table">
        <thead>
            <tr>
                <th>Work Order</th>
                <th>Status</th>
                <th>Vendor</th>
                <th>Scheduled</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var wo in _workOrders)
            {
                var captured = wo;
                <tr class="cockpit-wo-row" @onclick="() => OpenDetail(captured.Id)">
                    <td class="cockpit-wo-id">@captured.Id.Value</td>
                    <td><span class="cockpit-wo-chip">@captured.Status</span></td>
                    <td>@captured.AssignedVendorId.Value</td>
                    <td>@captured.ScheduledDate.ToShortDateString()</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<WorkOrder> _workOrders = new();
    private string _statusFilter = "";
    private string? _loadError;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsOnboarded)
        {
            Nav.NavigateTo("/onboarding", replace: true);
            return;
        }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loadError = null;
        _workOrders.Clear();
        try
        {
            var query = ListWorkOrdersQuery.Empty;
            if (!string.IsNullOrWhiteSpace(_statusFilter)
                && Enum.TryParse<WorkOrderStatus>(_statusFilter, ignoreCase: true, out var s))
                query = query with { Status = s };

            await foreach (var wo in Maintenance.ListWorkOrdersAsync(query, default))
                _workOrders.Add(wo);

            _workOrders.Sort((a, b) =>
            {
                var d = b.ScheduledDate.CompareTo(a.ScheduledDate);
                return d != 0 ? d : string.CompareOrdinal(a.Id.Value, b.Id.Value);
            });
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
    }

    private void OpenDetail(WorkOrderId id) => Nav.NavigateTo($"/cockpit/work-orders/{Uri.EscapeDataString(id.Value)}");
}

<style>
    .cockpit-wo-header { display: flex; justify-content: space-between; align-items: end; gap: 1rem; margin-bottom: 1.25rem; }
    .cockpit-wo-header h1 { font-size: 1.5rem; margin: 0 0 0.25rem; letter-spacing: -0.01em; }
    .cockpit-wo-meta { color: #6b7280; font-size: 0.875rem; margin: 0; }
    .cockpit-wo-filters { display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; color: #4b5563; }
    .cockpit-wo-filters select { border: 1px solid #d1d5db; border-radius: 0.25rem; padding: 0.25rem 0.5rem; font-size: 0.875rem; }
    .cockpit-wo-error { padding: 1rem; border: 1px solid #fecaca; background: #fef2f2; color: #991b1b; border-radius: 0.5rem; }
    .cockpit-wo-error p { margin: 0.5rem 0 0; color: #4b5563; }
    .cockpit-wo-empty { color: #6b7280; padding: 2rem 0; text-align: center; }
    .cockpit-wo-table { width: 100%; border-collapse: collapse; background: #fff; border: 1px solid #e5e7eb; border-radius: 0.5rem; overflow: hidden; font-size: 0.875rem; }
    .cockpit-wo-table thead { background: #f9fafb; }
    .cockpit-wo-table th { padding: 0.5rem 0.75rem; text-align: left; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: #6b7280; }
    .cockpit-wo-row { cursor: pointer; border-top: 1px solid #f3f4f6; }
    .cockpit-wo-row:hover { background: #f9fafb; }
    .cockpit-wo-row td { padding: 0.5rem 0.75rem; color: #374151; }
    .cockpit-wo-id { font-weight: 500; color: #2563eb; }
    .cockpit-wo-chip { display: inline-block; padding: 0.125rem 0.5rem; background: #f3f4f6; color: #1f2937; border-radius: 0.25rem; font-size: 0.75rem; }
</style>
