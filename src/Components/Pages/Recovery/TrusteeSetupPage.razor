@page "/recovery/trustee-setup"
@using System.Security.Cryptography
@using System.Threading
@using Sunfish.Anchor.Services
@using Sunfish.Foundation.Recovery
@implements IDisposable
@inject TrusteeSetupService SetupService
@inject NavigationManager Nav

<PageTitle>Trustee Setup · Recovery · Sunfish Anchor</PageTitle>

@* W#67 PR 5 — designate a trustee AND distribute the root-seed envelope
   in one step. Per ADR 0046-A6: trustees must be ONLINE during setup so
   the owner can Box the root seed against the trustee's X25519 public
   key. The Box ciphertext + nonce are persisted in the coordinator's
   per-trustee TrusteeEncryptedSeed entry; the trustee's local Anchor
   reads its own entry during the approval flow to re-encrypt the seed
   toward the recovering device. *@

<div class="recovery-trustee">
    <header>
        <a class="recovery-trustee__link" href="recovery/status">← Back to recovery status</a>
        <h1>Designate trustees</h1>
        <p class="recovery-trustee__hint">
            Add the people you trust to approve a recovery of this Sunfish identity.
            Get the trustee's NodeId, Ed25519 public key, AND X25519 DH public key
            out-of-band (Signal, encrypted email, in-person) and paste them below.
            Read the rendered DH fingerprint aloud to confirm.
        </p>
        <p class="recovery-trustee__warn">
            <strong>Trustee must be reachable during setup.</strong>
            We encrypt your root seed against their DH key right now so they
            can re-encrypt it for the recovering device later.
        </p>
    </header>

    <form @onsubmit="OnSubmitAsync" @onsubmit:preventDefault>
        <label>
            <span>Name (display only)</span>
            <input type="text" @bind="_name" placeholder="e.g. Sister Alice" />
        </label>

        <label>
            <span>NodeId</span>
            <input type="text" @bind="_nodeId" placeholder="node-id from trustee's invitation" />
        </label>

        <label>
            <span>Ed25519 public key (base64url, 32 bytes)</span>
            <textarea @bind="_publicKeyBase64Url" rows="3"
                      placeholder="paste base64url-encoded public key"></textarea>
        </label>

        <label>
            <span>X25519 DH public key (base64url, 32 bytes)</span>
            <textarea @bind="_dhPublicKeyBase64Url" rows="3"
                      placeholder="paste base64url-encoded X25519 public key"></textarea>
        </label>

        <button type="submit" disabled="@(_busy || !CanSubmit)">@(_busy ? "Designating + encrypting…" : "Designate trustee")</button>
    </form>

    @if (_error is not null)
    {
        <p class="recovery-trustee__error" role="alert">@_error</p>
    }

    @if (_lastDesignated is not null)
    {
        <section class="recovery-trustee__success">
            <strong>Trustee designated and seed envelope distributed.</strong>
            <p>
                Read <em>both</em> fingerprints aloud to the trustee to confirm
                no paste-swap between the Ed25519 and X25519 fields. A swap
                would silently drop their attestation at recovery time.
            </p>
            <dl class="recovery-trustee__fingerprints">
                <dt>Ed25519 (signing) fingerprint</dt>
                <dd class="recovery-trustee__fingerprint">@_lastEd25519Fingerprint</dd>
                <dt>X25519 (DH) fingerprint</dt>
                <dd class="recovery-trustee__fingerprint">@_lastFingerprint</dd>
            </dl>
            <p class="recovery-trustee__hint">
                Continue adding trustees (quorum is 3-of-5 by default) or
                <a href="recovery/status">return to recovery status</a>.
            </p>
        </section>
    }
</div>

@code {
    private string _name = "";
    private string _nodeId = "";
    private string _publicKeyBase64Url = "";
    private string _dhPublicKeyBase64Url = "";
    private string? _error;
    private string? _lastDesignated;
    private string? _lastFingerprint;
    private string? _lastEd25519Fingerprint;
    private bool _busy;
    // Council R-6: lifecycle-bound CT so an in-flight
    // SetupService.DesignateAndDistributeAsync call cancels when the
    // user navigates away from the page mid-encryption.
    private readonly CancellationTokenSource _cts = new();

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }

    private bool CanSubmit =>
        !string.IsNullOrWhiteSpace(_nodeId)
        && !string.IsNullOrWhiteSpace(_publicKeyBase64Url)
        && !string.IsNullOrWhiteSpace(_dhPublicKeyBase64Url);

    private async Task OnSubmitAsync()
    {
        _error = null; _lastDesignated = null; _lastFingerprint = null;
        if (!CanSubmit) return;

        byte[] publicKey;
        byte[] dhPublicKey;
        try
        {
            publicKey = Base64UrlDecode(_publicKeyBase64Url.Trim());
            dhPublicKey = Base64UrlDecode(_dhPublicKeyBase64Url.Trim());
        }
        catch (Exception ex)
        {
            _error = $"Key is not valid base64url: {ex.Message}";
            return;
        }
        if (publicKey.Length != 32)
        {
            _error = $"Ed25519 public key must decode to exactly 32 bytes; got {publicKey.Length}.";
            return;
        }
        if (dhPublicKey.Length != TrusteeDesignation.DHPublicKeyLength)
        {
            _error = $"X25519 DH public key must decode to exactly {TrusteeDesignation.DHPublicKeyLength} bytes; got {dhPublicKey.Length}.";
            return;
        }

        _busy = true;
        try
        {
            var outcome = await SetupService.DesignateAndDistributeAsync(
                _nodeId.Trim(), publicKey, dhPublicKey, _cts.Token);
            _lastDesignated = outcome.TrusteeNodeId;
            _lastFingerprint = outcome.TrusteeDHFingerprintHex;
            _lastEd25519Fingerprint = outcome.TrusteeEd25519FingerprintHex;
            _nodeId = ""; _publicKeyBase64Url = ""; _dhPublicKeyBase64Url = ""; _name = "";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private static byte[] Base64UrlDecode(string s)
    {
        var padded = s.Replace('-', '+').Replace('_', '/');
        switch (padded.Length % 4)
        {
            case 2: padded += "=="; break;
            case 3: padded += "="; break;
        }
        return Convert.FromBase64String(padded);
    }
}

<style>
    .recovery-trustee { max-width: 720px; margin: 0 auto; padding: 1rem 1.5rem; font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; }
    .recovery-trustee__link { color: #2563eb; font-size: 0.875rem; text-decoration: none; }
    .recovery-trustee__link:hover { text-decoration: underline; }
    .recovery-trustee h1 { font-size: 1.75rem; margin: 0.5rem 0 0.25rem; letter-spacing: -0.01em; }
    .recovery-trustee__hint { color: #6b7280; font-size: 0.875rem; margin: 0 0 1rem; line-height: 1.5; }
    .recovery-trustee__warn { padding: 0.75rem 1rem; background: #fffbeb; border: 1px solid #fde68a; color: #92400e; border-radius: 0.5rem; font-size: 0.875rem; line-height: 1.5; margin: 0 0 1rem; }
    .recovery-trustee form { display: flex; flex-direction: column; gap: 0.75rem; padding: 1rem 1.25rem; border: 1px solid #e5e7eb; background: #fff; border-radius: 0.5rem; }
    .recovery-trustee label { display: flex; flex-direction: column; gap: 0.25rem; font-size: 0.875rem; color: #374151; }
    .recovery-trustee input, .recovery-trustee textarea { padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.25rem; font-family: inherit; font-size: 0.875rem; }
    .recovery-trustee textarea { font-family: Consolas, Menlo, monospace; }
    .recovery-trustee button { padding: 0.5rem 1rem; background: #2563eb; color: #fff; border: 0; border-radius: 0.25rem; font-size: 0.875rem; cursor: pointer; }
    .recovery-trustee button:hover:not(:disabled) { background: #1d4ed8; }
    .recovery-trustee button:disabled { opacity: 0.5; cursor: not-allowed; }
    .recovery-trustee__error { padding: 0.75rem 1rem; background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; border-radius: 0.25rem; font-size: 0.875rem; margin: 1rem 0 0; }
    .recovery-trustee__success { margin-top: 1rem; padding: 1rem 1.25rem; background: #ecfdf5; border: 1px solid #a7f3d0; border-radius: 0.5rem; color: #047857; font-size: 0.875rem; }
    .recovery-trustee__success strong { display: block; margin-bottom: 0.25rem; }
    .recovery-trustee__fingerprints { display: grid; grid-template-columns: auto 1fr; column-gap: 1rem; row-gap: 0.5rem; margin: 0.75rem 0; }
    .recovery-trustee__fingerprints dt { color: #047857; font-weight: 500; font-size: 0.875rem; align-self: center; }
    .recovery-trustee__fingerprints dd { margin: 0; }
    .recovery-trustee__fingerprint { font-family: Consolas, Menlo, monospace; font-size: 1.125rem; color: #111827; background: #fff; padding: 0.5rem 0.75rem; border-radius: 0.25rem; border: 1px solid #d1fae5; }
</style>
