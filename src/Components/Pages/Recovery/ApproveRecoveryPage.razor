@page "/recovery/approve"
@using Microsoft.Extensions.Logging
@using Sunfish.Anchor.Services
@using Sunfish.Foundation.Recovery
@using Sunfish.Kernel.Sync.Identity
@inject IRecoveryCoordinator Recovery
@inject RecoveryAttestationSubmitter Submitter
@inject INodeIdentityProvider NodeIdentity
@inject ILogger<ApproveRecoveryPage> Logger

<PageTitle>Approve Recovery · Sunfish Anchor</PageTitle>

<div class="recovery-approve">
    <header>
        <a class="recovery-approve__link" href="recovery/status">← Back to recovery status</a>
        <h1>Approve recovery</h1>
    </header>

    @if (_status?.PendingRequest is { } req)
    {
        <section class="recovery-approve__pending">
            <h2>Pending request</h2>
            <dl>
                <dt>Requesting node</dt>
                <dd><code>@req.RequestingNodeId</code></dd>
                <dt>Requested at</dt>
                <dd>@req.RequestedAt.ToLocalTime()</dd>
                <dt>Quorum progress</dt>
                <dd>@_status.AttestationsReceived of @_status.QuorumThreshold</dd>
                <dt>Your trustee NodeId</dt>
                <dd><code>@NodeIdentity.Current.NodeId</code></dd>
            </dl>
        </section>

        @if (_result is null)
        {
            <button type="button" class="recovery-approve__approve"
                    disabled="@_submitting" @onclick="ApproveAsync">
                @(_submitting ? "Signing…" : "Sign + submit attestation")
            </button>
        }
        else
        {
            <section class="recovery-approve__success" role="status">
                <h2>Attestation submitted</h2>
                <p>
                    @if (_result.QuorumReached)
                    {
                        <text>
                            Quorum reached. Grace window started at
                            <strong>@_result.GracePeriodStartedAt?.ToLocalTime()</strong>.
                        </text>
                    }
                    else
                    {
                        <text>Attestation recorded. Waiting on other trustees.</text>
                    }
                </p>
            </section>
        }

        @if (_errorMessage is not null)
        {
            <section class="recovery-approve__error" role="alert">
                @_errorMessage
            </section>
        }
    }
    else
    {
        <section class="recovery-approve__idle">
            <p>No recovery is in flight on this node.</p>
        </section>
    }
</div>

@code {
    private RecoveryStatus? _status;
    private AttestationSubmissionResult? _result;
    private string? _errorMessage;
    private bool _submitting;

    protected override async Task OnInitializedAsync()
    {
        try { _status = await Recovery.GetStatusAsync(default); }
        catch (Exception ex) { Logger.LogError(ex, "Recovery status read failed"); }
    }

    private async Task ApproveAsync()
    {
        if (_status?.PendingRequest is not { } req) return;
        _submitting = true;
        _errorMessage = null;
        try
        {
            var outcome = await Submitter.SubmitAsync(req, default);
            if (!outcome.Accepted)
            {
                _errorMessage = "Attestation rejected — verify the trustee identity and the pending request hash.";
                return;
            }

            _result = outcome;

            try { _status = await Recovery.GetStatusAsync(default); }
            catch (Exception ex) { Logger.LogError(ex, "Recovery status refresh failed"); }
        }
        catch (InvalidOperationException ex)
        {
            _errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Approve recovery failed");
            _errorMessage = "Approval failed. See logs.";
        }
        finally
        {
            _submitting = false;
            StateHasChanged();
        }
    }
}

<style>
    .recovery-approve { max-width: 720px; margin: 0 auto; padding: 1rem 1.5rem; font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; }
    .recovery-approve__link { color: #2563eb; font-size: 0.875rem; text-decoration: none; }
    .recovery-approve__link:hover { text-decoration: underline; }
    .recovery-approve h1 { font-size: 1.75rem; margin: 0.5rem 0 1rem; letter-spacing: -0.01em; }
    .recovery-approve__pending { padding: 1rem 1.25rem; border: 1px solid #e5e7eb; background: #fff; border-radius: 0.5rem; }
    .recovery-approve__pending h2 { font-size: 1rem; margin: 0 0 0.5rem; }
    .recovery-approve dl { display: grid; grid-template-columns: auto 1fr; column-gap: 1rem; row-gap: 0.25rem; margin: 0; font-size: 0.875rem; }
    .recovery-approve dt { color: #6b7280; font-weight: 500; }
    .recovery-approve dd { margin: 0; color: #111827; }
    .recovery-approve code { font-family: Consolas, Menlo, monospace; }
    .recovery-approve__approve { margin-top: 1rem; padding: 0.5rem 1.25rem; background: #2563eb; color: #fff; border: 0; border-radius: 0.375rem; font-weight: 600; cursor: pointer; }
    .recovery-approve__approve:disabled { opacity: 0.5; cursor: not-allowed; }
    .recovery-approve__success { margin-top: 1rem; padding: 1rem 1.25rem; background: #ecfdf5; border: 1px solid #a7f3d0; color: #065f46; border-radius: 0.5rem; }
    .recovery-approve__success h2 { font-size: 1rem; margin: 0 0 0.5rem; }
    .recovery-approve__error { margin-top: 1rem; padding: 1rem 1.25rem; background: #fee2e2; border: 1px solid #fca5a5; color: #991b1b; border-radius: 0.5rem; }
    .recovery-approve__idle { margin-top: 1rem; padding: 1rem 1.25rem; background: #f9fafb; border: 1px solid #e5e7eb; color: #6b7280; border-radius: 0.5rem; }
</style>
