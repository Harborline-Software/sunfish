@page "/cockpit/vendors/{VendorIdValue}"
@layout CockpitLayout
@using Sunfish.Anchor.Services
@using Sunfish.Blocks.Maintenance.Models
@using Sunfish.Blocks.Maintenance.Services
@inject IMaintenanceService Maintenance
@inject IVendorPerformanceLog Performance
@inject AnchorSessionService Session
@inject NavigationManager Nav

<PageTitle>@(_vendor?.DisplayName ?? "Vendor") · Cockpit</PageTitle>

@if (_loadError is not null)
{
    <div class="cockpit-vendor-error">
        <strong>Failed to load vendor.</strong>
        <p>@_loadError</p>
        <a href="cockpit/vendors">← Back to vendors</a>
    </div>
}
else if (_notFound)
{
    <div class="cockpit-vendor-empty">
        <h2>Vendor not found</h2>
        <a href="cockpit/vendors">← Back to vendors</a>
    </div>
}
else if (_vendor is null)
{
    <p class="cockpit-vendor-loading">Loading vendor…</p>
}
else
{
    <header class="cockpit-vendor-detail-header">
        <a class="cockpit-vendor-link" href="cockpit/vendors">← Back to vendors</a>
        <h1>@_vendor.DisplayName</h1>
        <p class="cockpit-vendor-meta">@_vendor.Status · @_vendor.OnboardingState · @(string.Join(", ", _vendor.Specialties.Select(s => s.ToString())))</p>
    </header>

    <section class="cockpit-vendor-section">
        <h2>Contact</h2>
        <dl class="cockpit-vendor-grid">
            <dt>Name</dt>   <dd>@(_vendor.ContactName ?? "—")</dd>
            <dt>Email</dt>  <dd>@(_vendor.ContactEmail ?? "—")</dd>
            <dt>Phone</dt>  <dd>@(_vendor.ContactPhone ?? "—")</dd>
            <dt>W-9</dt>    <dd>@(_vendor.W9 is null ? "Awaiting" : "On file")</dd>
        </dl>
    </section>

    <section class="cockpit-vendor-section">
        <h2>Performance log (last 5)</h2>
        @if (_performance.Count == 0)
        {
            <p class="cockpit-vendor-muted">No performance records.</p>
        }
        else
        {
            <ul class="cockpit-vendor-list">
                @foreach (var p in _performance.TakeLast(5))
                {
                    <li>
                        <strong>@p.Event</strong>
                        <span class="cockpit-vendor-muted"> · @p.OccurredAt.ToLocalTime()</span>
                        @if (!string.IsNullOrEmpty(p.Notes))
                        {
                            <p class="cockpit-vendor-notes">@p.Notes</p>
                        }
                    </li>
                }
            </ul>
        }
    </section>

    <section class="cockpit-vendor-section">
        <h2>Work orders</h2>
        @if (_workOrders.Count == 0)
        {
            <p class="cockpit-vendor-muted">No work orders assigned.</p>
        }
        else
        {
            <ul class="cockpit-vendor-list">
                @foreach (var wo in _workOrders)
                {
                    var captured = wo;
                    <li>
                        <a href="cockpit/work-orders/@Uri.EscapeDataString(captured.Id.Value)" class="cockpit-vendor-link">@captured.Id.Value</a>
                        <span class="cockpit-vendor-muted"> · @captured.Status · scheduled @captured.ScheduledDate.ToShortDateString()</span>
                    </li>
                }
            </ul>
        }
    </section>
}

@code {
    [Parameter] public string? VendorIdValue { get; set; }

    private Vendor? _vendor;
    private List<VendorPerformanceRecord> _performance = new();
    private List<WorkOrder> _workOrders = new();
    private bool _notFound;
    private string? _loadError;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsOnboarded) { Nav.NavigateTo("/onboarding", replace: true); return; }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loadError = null; _notFound = false; _vendor = null; _performance.Clear(); _workOrders.Clear();
        if (string.IsNullOrWhiteSpace(VendorIdValue)) { _notFound = true; return; }

        try
        {
            _vendor = await Maintenance.GetVendorAsync(new VendorId(VendorIdValue), default);
            if (_vendor is null) { _notFound = true; return; }

            await foreach (var p in Performance.ListByVendorAsync(_vendor.Id, skip: null, take: null, default))
                _performance.Add(p);

            await foreach (var wo in Maintenance.ListWorkOrdersAsync(
                ListWorkOrdersQuery.Empty with { VendorId = _vendor.Id }, default))
                _workOrders.Add(wo);

            _workOrders.Sort((a, b) => b.ScheduledDate.CompareTo(a.ScheduledDate));
        }
        catch (Exception ex) { _loadError = ex.Message; }
    }
}

<style>
    .cockpit-vendor-loading { color: #6b7280; padding: 3rem 0; text-align: center; }
    .cockpit-vendor-error { padding: 1rem; border: 1px solid #fecaca; background: #fef2f2; color: #991b1b; border-radius: 0.5rem; }
    .cockpit-vendor-empty { padding: 3rem 1.5rem; text-align: center; border: 1px solid #e5e7eb; background: #fff; border-radius: 0.5rem; }
    .cockpit-vendor-empty h2 { font-size: 1.125rem; margin: 0 0 1rem; }
    .cockpit-vendor-link { color: #2563eb; font-size: 0.875rem; text-decoration: none; }
    .cockpit-vendor-link:hover { text-decoration: underline; }
    .cockpit-vendor-detail-header { margin-bottom: 1.5rem; }
    .cockpit-vendor-detail-header h1 { font-size: 1.5rem; margin: 0.5rem 0 0.25rem; letter-spacing: -0.01em; }
    .cockpit-vendor-meta { color: #6b7280; font-size: 0.875rem; margin: 0; }
    .cockpit-vendor-section { padding: 1rem 1.25rem; border: 1px solid #e5e7eb; background: #fff; border-radius: 0.5rem; margin-bottom: 0.75rem; }
    .cockpit-vendor-section h2 { font-size: 1rem; margin: 0 0 0.5rem; }
    .cockpit-vendor-muted { color: #6b7280; font-size: 0.875rem; }
    .cockpit-vendor-grid { display: grid; grid-template-columns: auto 1fr; column-gap: 1rem; row-gap: 0.25rem; margin: 0; font-size: 0.875rem; }
    .cockpit-vendor-grid dt { color: #6b7280; font-weight: 500; }
    .cockpit-vendor-grid dd { margin: 0; color: #111827; }
    .cockpit-vendor-list { list-style: none; padding: 0; margin: 0; }
    .cockpit-vendor-list li { padding: 0.375rem 0; border-bottom: 1px solid #f3f4f6; font-size: 0.875rem; }
    .cockpit-vendor-list li:last-child { border-bottom: 0; }
    .cockpit-vendor-notes { color: #6b7280; font-size: 0.75rem; margin: 0.125rem 0 0; }
</style>
