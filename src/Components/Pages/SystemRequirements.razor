@page "/system-requirements/{BundleId}"
@using Microsoft.Extensions.Localization
@using Microsoft.Maui.Devices
@using Sunfish.Anchor.Localization
@using Sunfish.Foundation.Catalog.Bundles
@using Sunfish.Foundation.MissionSpace
@inject IBundleCatalog Catalog
@inject IMissionEnvelopeProvider EnvelopeProvider
@inject IMinimumSpecResolver Resolver
@inject IInstallForceEnableSurface ForceEnableSurface
@inject AnchorSessionService Session
@inject IStringLocalizer<SharedResource> L
@inject NavigationManager Nav

<PageTitle>Sunfish Anchor — @L["sysreq.title.preinstall"]</PageTitle>

<main role="main" class="sysreq-page" aria-labelledby="sysreq-heading">
    <h1 id="sysreq-heading">@L["sysreq.title.preinstall"]</h1>

    @* Single permanent live region covering loading → not-found → verdict transitions.
       Pre-exists in DOM from first render so Chromium/WebView2 fires the announcement
       reliably when content changes (SC 4.1.3; WCAG council B5 + B6). *@
    <div class="sysreq-verdict @_verdictWrapperCss"
         role="status" aria-live="polite" aria-atomic="true">
        @_liveRegionText
    </div>

    @if (!_bundleNotFound && _result is not null)
    {
        @* B9: aria-label localized via IStringLocalizer<SharedResource>. *@
        <ul class="sysreq-dim-list" role="list" aria-label="@L["sysreq.dim_list.label"]">
            @foreach (var dim in _result.Dimensions)
            {
                <SystemRequirementsDimensionRow Eval="dim" />
            }
        </ul>

        <div class="sysreq-footer">
            @if (_result.Overall == OverallVerdict.Block)
            {
                @* B4: button text changes + polite sr-only live region during in-flight
                   force-install; aria-describedby wired only while in-progress. *@
                <button class="sysreq-btn sysreq-btn--danger"
                        disabled="@_forceInProgress"
                        aria-describedby="@(_forceInProgress ? "force-progress" : null)"
                        @onclick="OnForceInstallAsync">
                    @if (_forceInProgress)
                    {
                        @L["sysreq.action.force_install_in_progress"]
                    }
                    else
                    {
                        @L["sysreq.action.force_install"]
                    }
                </button>
                @if (_forceInProgress)
                {
                    <span id="force-progress" class="sr-only" role="status" aria-live="polite">
                        @L["sysreq.action.force_install_in_progress"]
                    </span>
                }
            }
            else if (_result.Overall == OverallVerdict.WarnOnly)
            {
                <button class="sysreq-btn sysreq-btn--warn" @onclick="OnInstallAnyway">
                    @L["sysreq.action.install_anyway"]
                </button>
            }
            else
            {
                <button class="sysreq-btn sysreq-btn--primary" @onclick="OnContinue">
                    @L["sysreq.action.continue"]
                </button>
            }
        </div>
    }
</main>

@code {
    [Parameter] public string BundleId { get; set; } = string.Empty;

    private SystemRequirementsResult? _result;
    private MissionEnvelope? _envelope;
    private bool _bundleNotFound;
    private bool _forceInProgress;
    private string _liveRegionText = string.Empty;
    private string _verdictWrapperCss = "sysreq-verdict--loading";

    protected override void OnInitialized()
    {
        // Set loading text synchronously so the first render shows it immediately
        // before OnInitializedAsync runs (Blazor renders once before awaiting).
        _liveRegionText = L["sysreq.status.checking"];
    }

    protected override async Task OnInitializedAsync()
    {
        if (!Catalog.TryGet(BundleId, out var manifest) || manifest is null)
        {
            _bundleNotFound = true;
            // B7: localized error string; role="status" (not alert) — bundle-not-found
            // is not an interruption-worthy event. Format {0} = BundleId.
            // GetString overload (not indexer) to pass the format arg; the analyzer's
            // Pattern B matches .GetString("key"[, args]) so SUNFISH_I18N_002 is satisfied.
            _liveRegionText = L.GetString("sysreq.error.bundle_not_found", BundleId);
            _verdictWrapperCss = "sysreq-verdict--block";
            return;
        }

        // Convert deprecated Catalog.Bundles.MinimumSpec to canonical MissionSpace.MinimumSpec.
        // Both types share the same Policy enum value names; field types are wire-format
        // compatible. Scheduled for type unification 2026-08-01 per MinimumSpec.cs comment.
        var spec = manifest.Requirements is { } catalogSpec
            ? new Sunfish.Foundation.MissionSpace.MinimumSpec
            {
                Policy = Enum.Parse<Sunfish.Foundation.MissionSpace.SpecPolicy>(catalogSpec.Policy.ToString())
            }
            : new Sunfish.Foundation.MissionSpace.MinimumSpec
            {
                Policy = Sunfish.Foundation.MissionSpace.SpecPolicy.Recommended
            };

        _envelope = await EnvelopeProvider.GetCurrentAsync();
        var platformKey = SystemRequirementsViewHelpers.GetPlatformKey(DeviceInfo.Current.Platform.ToString());
        _result = await Resolver.EvaluateAsync(spec, _envelope, platformKey);

        // Compute verdict text using static key literals (SUNFISH_I18N_002 compliance).
        (_liveRegionText, _verdictWrapperCss) = _result.Overall switch
        {
            OverallVerdict.Pass     => (L["sysreq.verdict.pass"],  "sysreq-verdict--pass"),
            OverallVerdict.WarnOnly => (L["sysreq.verdict.warn"],  "sysreq-verdict--warn"),
            _                       => (L["sysreq.verdict.block"], "sysreq-verdict--block"),
        };
    }

    private async Task OnForceInstallAsync()
    {
        if (_result is null || _envelope is null)
            return;

        _forceInProgress = true;
        try
        {
            var blockedDims = _result.Dimensions
                .Where(d => d.Outcome == DimensionPassFail.Fail && d.Policy == DimensionPolicyKind.Required)
                .Select(d => d.Dimension)
                .ToList();

            await ForceEnableSurface.RequestAsync(new InstallForceRequest
            {
                OperatorPrincipalId = Session.NodeId ?? string.Empty,
                Reason = "Operator force-install from system requirements page",
                OverrideTargets = blockedDims,
                EnvelopeHash = _envelope.EnvelopeHash,
                Platform = SystemRequirementsViewHelpers.GetPlatformKey(DeviceInfo.Current.Platform.ToString()),
            });
        }
        finally
        {
            _forceInProgress = false;
        }
    }

    private void OnInstallAnyway() { }

    private void OnContinue() { }
}
