@inject Sunfish.Anchor.Services.AnchorSessionService Session
<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Sunfish Anchor</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Dashboard
            </NavLink>
        </div>
        @if (!Session.IsOnboarded)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="onboarding">
                    <span class="bi bi-qr-code-scan" aria-hidden="true"></span> Onboarding
                </NavLink>
            </div>
        }
        else
        {
            @* Wave 6.8 — team-switcher entry point. Only surfaced post-onboarding
               because adding a second team requires an active first team. *@
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="teams">
                    <span class="bi bi-people-fill" aria-hidden="true"></span> Teams
                </NavLink>
            </div>
            @* W#59 Phase 5 — crew chat entry. Surfaced post-onboarding so the
               operator has at least one team materialized; the chat page itself
               renders an empty-state panel when no active team is selected. *@
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="chat">
                    <span class="bi bi-chat-dots-fill" aria-hidden="true"></span> Chat
                </NavLink>
            </div>
            @* W#29 Phase 1 — owner cockpit entry. Lists managed properties and
               (in PR 2–5) drills into work orders / vendors / dashboards. *@
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="cockpit">
                    <span class="bi bi-grid-1x2-fill" aria-hidden="true"></span> Cockpit
                </NavLink>
            </div>
            @* W#63 Phase 1 — ADR 0046 recovery status surface. Other 4
               recovery pages (TrusteeSetup / InitiateRecovery /
               ApproveRecovery / PaperKey) deferred pending UX ruling. *@
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="recovery/status">
                    <span class="bi bi-shield-lock" aria-hidden="true"></span> Recovery
                </NavLink>
            </div>
            @* W#51 Phase 4 — Quarterdeck entry-point surface (ADR 0080).
               Root navigation landing; DepartmentNavPanel owns the main
               landmark + department links + skip-link. *@
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="quarterdeck">
                    <span class="bi bi-compass-fill" aria-hidden="true"></span> Quarterdeck
                </NavLink>
            </div>
            @* W#55 Phase 4 — Ship's Office aggregation surface (ADR 0083).
               Visible to all post-onboarding sessions. A1 council note: the link
               existence is not sensitive; ShipsOfficeBlock gates ViewShipsOffice
               permission before rendering document data. Route-level gate in
               ShipsOfficePage.razor enforces Session.IsOnboarded (B1 council fix). *@
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="ships-office">
                    <span class="bi bi-file-earmark-text-fill" aria-hidden="true"></span> Ship's Office
                </NavLink>
            </div>
            @* W#50 Phase 4 — Engine Room observability surface (ADR 0079).
               Read-only panels (HealthBanner + MainPropulsion + Electrical) are
               wired; DamageControlPanel deferred until W#51 Phase 4 lands full
               ship-level permission + audit wiring. *@
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="engine-room">
                    <span class="bi bi-gear-fill" aria-hidden="true"></span> Engine Room
                </NavLink>
            </div>
            @* W#54 Phase 4 — Sick Bay aggregation surface (ADR 0082).
               SickBayBlock gates ViewPharmacy internally; Anchor single-operator
               posture grants all permissions via AnchorGrantAllPermissionResolver. *@
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="sick-bay">
                    <span class="bi bi-heart-pulse-fill" aria-hidden="true"></span> Sick Bay
                </NavLink>
            </div>
            @* W#58 Phase 1b — Identity Atlas pages. B1 fix: group with heading so AT users
               get the section label; role=group + aria-labelledby gives grouping context. *@
            <div role="group" aria-labelledby="identity-nav-label">
                <h3 id="identity-nav-label" class="nav-section-label px-3">My Identity</h3>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="identity/profile">
                        <span class="bi bi-person-fill" aria-hidden="true"></span> Profile
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="identity/keys">
                        <span class="bi bi-key-fill" aria-hidden="true"></span> Keys
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="identity/recovery">
                        <span class="bi bi-shield-fill-check" aria-hidden="true"></span> Recovery
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="identity/teams">
                        <span class="bi bi-diagram-3-fill" aria-hidden="true"></span> Team Overview
                    </NavLink>
                </div>
            </div>
        }
            @* W#48 Phase 4 — Integration Atlas config surface (ADR 0067). *@
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="settings/integrations">
                    <span class="bi bi-plug-fill" aria-hidden="true"></span> Integrations
                </NavLink>
            </div>
        @*
            Nav items (Reports, Audit, Bundles) stay deferred per
            accelerators/anchor/README.md. The Wave 3.3+3.4 scope is deliberately
            narrow: status-bar + home + onboarding only.
        *@
    </nav>
</div>
