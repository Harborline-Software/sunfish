# Normalize line endings — LF in the repo everywhere.
# Prevents Windows CRLF drift on cross-platform files (Husky hooks, scripts, source).

# Default: detect text vs binary, store text as LF
* text=auto eol=lf

# Windows-only scripts must have CRLF on checkout
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Explicit text
*.cs            text
*.csproj        text
*.slnx          text
*.sln           text
*.json          text
*.md            text
*.yml           text
*.yaml          text
*.razor         text
*.razor.css     text
*.html          text
*.css           text
*.js            text
*.ts            text
*.tsx           text
*.mjs           text
*.toml          text
*.lock          text
*.config        text
*.props         text
*.targets       text
*.xml           text
*.rs            text
Directory.Build.props    text
Directory.Packages.props text

# Binary — never normalize
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.svg   text
*.pdf   binary
*.zip   binary
*.7z    binary
*.gz    binary
*.tar   binary
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary
*.pfx   binary
*.snk   binary
*.dll   binary
*.exe   binary
*.bin   binary
